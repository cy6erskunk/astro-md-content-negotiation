{
  "name": "astro-md-content-negotiation",
  "version": "0.1.1",
  "description": "Astro integration that generates Markdown versions of every page at build time, making your site readable by LLMs and AI crawlers, and enabling HTTP content negotiation.",
  "keywords": [
    "astro",
    "astro-integration",
    "utils",
    "seo",
    "markdown",
    "llm",
    "content-negotiation",
    "turndown",
    "html-to-markdown"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/cy6erskunk/astro-md-content-negotiation.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "adapters",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test 'src/**/*.test.ts'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "fast-glob": "3.3.3",
    "turndown": "7.2.4",
    "turndown-plugin-gfm": "1.0.2"
  },
  "devDependencies": {
    "@types/node": "25.9.0",
    "@types/turndown": "5.0.6",
    "astro": "6.3.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "astro": "6.3.1"
  }
}
